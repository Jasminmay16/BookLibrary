@inject HttpClient Http
@page "/"

<PageTitle>Front page</PageTitle>

<div class="page-header">
    <input class="search-bar" type="search" placeholder="Search books..." />
    <h1>Welcome to the Library!</h1>
</div>

<div class="book-section">
    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="error">Error: @Error</div>
    }
    <div class="book-grid">
        @if (IsLoading)
        {
            <p>Loading books...</p>
        }
        else if (Books == null || Books.Count == 0)
        {
            <p>No books found.</p>
        }
        else
        {
            @for (var i = 0; i < Books.Count; i++)
            {
                var book = Books[i];
                <div class="book-card">
                    <div class="rank">
                        @(i + 1)
                    </div>

                    <img src="@book.ImageUrl" class="book-image" />

                    <div class="book-info">
                        <h3>@book.Title</h3>
                        <p class="author">@book.Author</p>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<GetBooksDto> Books = new();
    private bool IsLoading = true;
    private bool IsAdding = false;
    private string? Error;

    protected override async Task OnInitializedAsync()
    {
        await LoadBooks();
    }

    private async Task LoadBooks()
    {
        IsLoading = true;
        Error = null;
        try
        {
            var resp = await Http.GetAsync("api/books");
            var body = await resp.Content.ReadAsStringAsync();
            if (!resp.IsSuccessStatusCode)
            {
                Error = $"Request failed: {resp.StatusCode}: {body}";
                Books = new List<GetBooksDto>();
            }
            else
            {
                try
                {
                    Books = System.Text.Json.JsonSerializer.Deserialize<List<GetBooksDto>>(body, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new List<GetBooksDto>();
                }
                catch (Exception ex)
                {
                    Error = $"Deserialization error: {ex.Message}. Body: {body}";
                    Books = new List<GetBooksDto>();
                }
            }
        }
        catch (Exception ex)
        {
            Error = ex.Message;
            Books = new List<GetBooksDto>();
        }
        finally
        {
            IsLoading = false;
        }
    }
}
